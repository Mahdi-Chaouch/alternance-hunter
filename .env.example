# API token required by backend_api.py and Next.js proxy routes.
PIPELINE_API_TOKEN=change-me

# Comma-separated list of allowed CORS origins for backend_api.py.
# Set this on Render to restrict who can call the backend.
ALLOWED_ORIGINS=https://alternance-hunter.com

# Backward-compatible alias supported by backend_api.py.
API_TOKEN=change-me

# Optional: convenience default used by local tooling/scripts.
PIPELINE_API_BASE_URL=http://127.0.0.1:8000

# France Travail Offres API (for Python worker / pipeline).
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
FRANCE_TRAVAIL_SCOPE=
FRANCE_TRAVAIL_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token?realm=/partenaire
FRANCE_TRAVAIL_API_BASE_URL=https://api.francetravail.io
